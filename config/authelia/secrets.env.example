# Authelia secrets — copy to secrets.env (gitignored) and fill in real values.
# Each value is read by Authelia as an AUTHELIA_<config.path.upper_snake> env var, so
# secrets stay out of configuration.yml (and out of git). Replace every REPLACE_ME
# placeholder with a unique long random value (e.g. `openssl rand -hex 64`); in
# production, source these from a secret manager rather than a flat file on disk.
AUTHELIA_IDENTITY_VALIDATION_RESET_PASSWORD_JWT_SECRET=REPLACE_ME_with_a_long_random_jwt_secret
AUTHELIA_SESSION_SECRET=REPLACE_ME_with_a_long_random_session_secret
AUTHELIA_STORAGE_ENCRYPTION_KEY=REPLACE_ME_with_a_long_random_encryption_key
# LDAP bind password for cn=john; must match the seeded glauth user (seed/glauth.sql).
AUTHELIA_AUTHENTICATION_BACKEND_LDAP_PASSWORD=password
