# Authelia secrets for local use — copy to secrets.env (gitignored) and adjust.
# Each value is read by Authelia as an AUTHELIA_<config.path.upper_snake> env var, so
# secrets stay out of configuration.yml (and out of git). The placeholders below match
# the local stack; replace with strong values before any real use.
AUTHELIA_IDENTITY_VALIDATION_RESET_PASSWORD_JWT_SECRET=insecure_poc_jwt_secret_change_me_please_1234
AUTHELIA_SESSION_SECRET=insecure_poc_session_secret_change_me_1234
AUTHELIA_STORAGE_ENCRYPTION_KEY=insecure_poc_encryption_key_change_me
AUTHELIA_AUTHENTICATION_BACKEND_LDAP_PASSWORD=password
