diff --git a/v2/pkg/embed/libsql.go b/v2/pkg/embed/libsql.go
new file mode 100644
index 0000000..dd411af
--- /dev/null
+++ b/v2/pkg/embed/libsql.go
@@ -0,0 +1,79 @@
+//go:build embedlibsql
+
+// Package embed (libsql variant) provides a libsql-backed glauth datastore that
+// is compiled directly into the glauth binary (datastore = "embed"), avoiding the
+// fragile Go-plugin (.so) mechanism. It mirrors the upstream glauth-sqlite backend
+// but talks to a remote sqld over Hrana via the go-libsql driver.
+//
+// The schema and all runtime queries are SQLite-compatible, so they are reused
+// verbatim from the sqlite backend (the only fix is the upstream "TYEXT" typo).
+package embed
+
+import (
+	"database/sql"
+
+	// go-libsql registers the database/sql driver "libsql" (CGO).
+	_ "github.com/tursodatabase/go-libsql"
+
+	"github.com/glauth/glauth/v2/pkg/handler"
+	"github.com/glauth/glauth/v2/pkg/plugins"
+)
+
+// LibsqlBackend implements plugins.SqlBackend against a libsql/sqld database.
+type LibsqlBackend struct{}
+
+// NewLibsqlHandler builds a glauth handler backed by libsql.
+func NewLibsqlHandler(opts ...handler.Option) handler.Handler {
+	return plugins.NewDatabaseHandler(LibsqlBackend{}, opts...)
+}
+
+func (b LibsqlBackend) GetDriverName() string { return "libsql" }
+
+func (b LibsqlBackend) GetPrepareSymbol() string { return "?" }
+
+// CreateSchema creates the glauth tables if they do not exist. Each statement is
+// executed on its own (go-libsql's Exec only runs the first statement of a
+// multi-statement string).
+func (b LibsqlBackend) CreateSchema(db *sql.DB) {
+	stmts := []string{
+		`CREATE TABLE IF NOT EXISTS users (
+	id INTEGER PRIMARY KEY,
+	name TEXT NOT NULL,
+	uidnumber INTEGER NOT NULL,
+	primarygroup INTEGER NOT NULL,
+	othergroups TEXT DEFAULT '',
+	givenname TEXT DEFAULT '',
+	sn TEXT DEFAULT '',
+	mail TEXT DEFAULT '',
+	loginshell TEXT DEFAULT '',
+	homedirectory TEXT DEFAULT '',
+	disabled SMALLINT DEFAULT 0,
+	passsha256 TEXT DEFAULT '',
+	passbcrypt TEXT DEFAULT '',
+	otpsecret TEXT DEFAULT '',
+	yubikey TEXT DEFAULT '',
+	sshkeys TEXT DEFAULT '',
+	custattr TEXT DEFAULT '{}')`,
+		`CREATE UNIQUE INDEX IF NOT EXISTS idx_user_name on users(name)`,
+		`CREATE TABLE IF NOT EXISTS ldapgroups (id INTEGER PRIMARY KEY, name TEXT NOT NULL, gidnumber INTEGER NOT NULL)`,
+		`CREATE UNIQUE INDEX IF NOT EXISTS idx_group_name on ldapgroups(name)`,
+		`CREATE TABLE IF NOT EXISTS includegroups (id INTEGER PRIMARY KEY, parentgroupid INTEGER NOT NULL, includegroupid INTEGER NOT NULL)`,
+		`CREATE TABLE IF NOT EXISTS capabilities (id INTEGER PRIMARY KEY, userid INTEGER NOT NULL, action TEXT NOT NULL, object TEXT NOT NULL)`,
+	}
+	for _, s := range stmts {
+		// Errors are intentionally ignored to match upstream behavior (IF NOT EXISTS).
+		_, _ = db.Exec(s)
+	}
+}
+
+// MigrateSchema applies legacy fixups. On a fresh libsql database these are all
+// no-ops (the sshkeys column already exists; the legacy "groups" table does not).
+func (b LibsqlBackend) MigrateSchema(db *sql.DB, checker func(*sql.DB, string, string) bool) {
+	if !checker(db, "users", "sshkeys") {
+		_, _ = db.Exec("ALTER TABLE users ADD COLUMN sshkeys TEXT DEFAULT ''")
+	}
+	if checker(db, "groups", "name") {
+		_, _ = db.Exec("DROP TABLE ldapgroups")
+		_, _ = db.Exec("ALTER TABLE groups RENAME TO ldapgroups")
+	}
+}
diff --git a/v2/pkg/plugins/basesqlhandler.go b/v2/pkg/plugins/basesqlhandler.go
index ceb517b..6b1341c 100644
--- a/v2/pkg/plugins/basesqlhandler.go
+++ b/v2/pkg/plugins/basesqlhandler.go
@@ -12,6 +12,7 @@ import (
 	"sort"
 	"strconv"
 	"strings"
+	"time"
 
 	"github.com/rs/zerolog"
 	"github.com/uptrace/opentelemetry-go-extra/otelsql"
@@ -62,12 +63,40 @@ func NewDatabaseHandler(sqlBackend SqlBackend, opts ...handler.Option) handler.H
 	options := handler.NewOptions(opts...)
 
 	// Note: we will never terminate this connection pool.
-	db, err := otelsql.Open(
-		sqlBackend.GetDriverName(),
-		options.Backend.Database,
-		otelsql.WithAttributes(otlpDriverAttribute(sqlBackend)),
-		otelsql.WithDBName(options.Backend.Database),
-	)
+	var db *sql.DB
+	var err error
+	if sqlBackend.GetDriverName() == "libsql" {
+		// go-libsql returns driver.ErrSkip from some fast paths, which the otelsql
+		// wrapper (v0.2.3) surfaces as a fatal Ping error. Use the plain
+		// database/sql opener for libsql (DB-layer OTEL tracing is not needed here).
+		//
+		// The libsql auth token (JWT) for a secured/remote sqld is read from the
+		// GLAUTH_LIBSQL_AUTH_TOKEN environment variable, so it never has to be written
+		// in plaintext into glauth.cfg. It is appended to the DSN as the authToken
+		// query parameter (go-libsql reads the token from there).
+		dsn := options.Backend.Database
+		if token := os.Getenv("GLAUTH_LIBSQL_AUTH_TOKEN"); token != "" && !strings.Contains(dsn, "authToken=") {
+			sep := "?"
+			if strings.Contains(dsn, "?") {
+				sep = "&"
+			}
+			dsn = fmt.Sprintf("%s%sauthToken=%s", dsn, sep, token)
+		}
+		db, err = sql.Open(sqlBackend.GetDriverName(), dsn)
+		if err == nil {
+			// Remote sqld expires idle Hrana streams (STREAM_EXPIRED). Recycle idle
+			// connections well before that so we never reuse an expired stream.
+			db.SetConnMaxIdleTime(2 * time.Second)
+			db.SetConnMaxLifetime(25 * time.Second)
+		}
+	} else {
+		db, err = otelsql.Open(
+			sqlBackend.GetDriverName(),
+			options.Backend.Database,
+			otelsql.WithAttributes(otlpDriverAttribute(sqlBackend)),
+			otelsql.WithDBName(options.Backend.Database),
+		)
+	}
 
 	if err != nil {
 		options.Logger.Error().Err(err).Msg(fmt.Sprintf("unable to open SQL database named '%s'", options.Backend.Database))
