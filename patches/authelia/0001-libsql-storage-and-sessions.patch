diff --git a/internal/storage/sql_provider_backend_libsql.go b/internal/storage/sql_provider_backend_libsql.go
new file mode 100644
index 0000000..d43955f
--- /dev/null
+++ b/internal/storage/sql_provider_backend_libsql.go
@@ -0,0 +1,57 @@
+package storage
+
+import (
+	"fmt"
+	"strings"
+	"time"
+
+	sqlx "github.com/rpadovani/sqlx-v2"
+	_ "github.com/tursodatabase/go-libsql" // registers the "libsql" database/sql driver (CGO).
+
+	"github.com/authelia/authelia/v4/internal/configuration/schema"
+)
+
+// LibSQLProvider is a libSQL/sqld provider. libSQL is SQLite-compatible, so this
+// reuses the SQLite SQL dialect, queries and migrations directory naming; only the
+// driver name and DSN differ. It talks to a remote sqld over Hrana via go-libsql.
+type LibSQLProvider struct {
+	SQLProvider
+}
+
+// NewLibSQLProvider constructs a libSQL provider talking to a remote sqld server.
+func NewLibSQLProvider(config *schema.Configuration) (provider *LibSQLProvider) {
+	provider = &LibSQLProvider{
+		SQLProvider: NewSQLProvider(config, providerLibSQL, "libsql", libsqlDataSourceName(config.Storage.LibSQL)),
+	}
+
+	// libSQL is SQLite-compatible: reuse the SQLite existing-tables query.
+	provider.sqlSelectExistingTables = querySQLiteSelectExistingTables
+
+	// Remote sqld expires idle Hrana streams (STREAM_EXPIRED error on reuse). Recycle
+	// idle/old pooled connections well before that so we never reuse an expired stream.
+	if wrap, ok := provider.db.(*SQLXWrapDB); ok {
+		wrap.SetConnMaxIdleTime(2 * time.Second)
+		wrap.SetConnMaxLifetime(25 * time.Second)
+	}
+
+	return provider
+}
+
+// libsqlDataSourceName builds the go-libsql DSN from the configured URL and optional auth token.
+func libsqlDataSourceName(config *schema.StorageLibSQL) (dsn string) {
+	if config.AuthToken == "" {
+		return config.URL
+	}
+
+	sep := "?"
+	if strings.Contains(config.URL, "?") {
+		sep = "&"
+	}
+
+	return fmt.Sprintf("%s%sauthToken=%s", config.URL, sep, config.AuthToken)
+}
+
+func init() {
+	// libSQL uses SQLite-style "?" positional placeholders; tell sqlx so Rebind is a no-op.
+	sqlx.BindDriver("libsql", sqlx.QUESTION)
+}
