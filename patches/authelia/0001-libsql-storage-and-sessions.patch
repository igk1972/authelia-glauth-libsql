+// schemaMigrateExec executes a migration's SQL. The libsql driver (go-libsql) only
+// runs the first statement of a multi-statement Exec, so for libsql the script is
+// split into individual statements executed in order. The libsql migration files are
+// plain DDL (no triggers, no ';' inside string literals), so a simple split is safe.
+func (p *SQLProvider) schemaMigrateExec(ctx context.Context, conn SQLXConnection, query string) (err error) {
+	if p.name != providerLibSQL {
+		_, err = conn.ExecContext(ctx, query)
+
+		return err
+	}
+
+	for _, stmt := range strings.Split(query, ";") {
+		if strings.TrimSpace(stmt) == "" {
+			continue
+		}
+
+		if _, err = conn.ExecContext(ctx, stmt); err != nil {
+			return err
+		}
+	}
+
+	return nil
+}
+
 func (p *SQLProvider) schemaMigrateApply(ctx context.Context, conn SQLXConnection, migration model.SchemaMigration) (err error) {
 	if migration.NotEmpty() {
-		if _, err = conn.ExecContext(ctx, migration.Query); err != nil {
+		if err = p.schemaMigrateExec(ctx, conn, migration.Query); err != nil {
 			return fmt.Errorf(errFmtFailedMigration, migration.Version, migration.Name, err)
 		}
 
