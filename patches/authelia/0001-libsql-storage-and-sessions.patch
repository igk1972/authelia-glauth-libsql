diff --git a/internal/session/libsql/provider.go b/internal/session/libsql/provider.go
new file mode 100644
index 0000000..1cf6bff
--- /dev/null
+++ b/internal/session/libsql/provider.go
@@ -0,0 +1,168 @@
+// Package libsql provides a fasthttp/session Provider backed by a remote
+// libSQL/sqld server (via the go-libsql driver). It mirrors the schema and query
+// semantics of fasthttp/session's bundled sqlite3 provider, but binds the session
+// payload as a BLOB ([]byte) so Authelia's AES-GCM-encrypted (binary) session data
+// round-trips cleanly, and tunes the connection pool for sqld's Hrana stream expiry.
+package libsql
+
+import (
+	"database/sql"
+	"fmt"
+	"strings"
+	"time"
+
+	_ "github.com/tursodatabase/go-libsql" // registers the "libsql" database/sql driver (CGO).
+)
+
+// Config configures the libSQL session Provider.
+type Config struct {
+	URL       string
+	AuthToken string
+	Table     string
+}
+
+// Provider is a fasthttp/session.Provider storing sessions in libSQL/sqld.
+type Provider struct {
+	db    *sql.DB
+	table string
+
+	sqlGet        string
+	sqlSave       string
+	sqlRegenerate string
+	sqlInsert     string
+	sqlDestroy    string
+	sqlCount      string
+	sqlGC         string
+}
+
+// New opens the connection, ensures the schema exists and returns the Provider.
+func New(config Config) (provider *Provider, err error) {
+	table := config.Table
+	if table == "" {
+		table = "session"
+	}
+
+	dsn := config.URL
+
+	if config.AuthToken != "" {
+		sep := "?"
+		if strings.Contains(dsn, "?") {
+			sep = "&"
+		}
+
+		dsn = fmt.Sprintf("%s%sauthToken=%s", dsn, sep, config.AuthToken)
+	}
+
+	var db *sql.DB
+
+	if db, err = sql.Open("libsql", dsn); err != nil {
+		return nil, err
+	}
+
+	// Remote sqld expires idle Hrana streams (STREAM_EXPIRED); recycle connections early.
+	db.SetConnMaxIdleTime(2 * time.Second)
+	db.SetConnMaxLifetime(25 * time.Second)
+
+	provider = &Provider{
+		db:    db,
+		table: table,
+
+		sqlGet:        fmt.Sprintf("SELECT data FROM %s WHERE id=?", table),
+		sqlSave:       fmt.Sprintf("UPDATE %s SET data=?,last_active=?,expiration=? WHERE id=?", table),
+		sqlRegenerate: fmt.Sprintf("UPDATE %s SET id=?,last_active=?,expiration=? WHERE id=?", table),
+		sqlInsert:     fmt.Sprintf("INSERT INTO %s (id, data, last_active, expiration) VALUES (?,?,?,?)", table),
+		sqlDestroy:    fmt.Sprintf("DELETE FROM %s WHERE id=?", table),
+		sqlCount:      fmt.Sprintf("SELECT count(id) FROM %s", table),
+		sqlGC:         fmt.Sprintf("DELETE FROM %s WHERE last_active+expiration<=? AND expiration<>0", table),
+	}
+
+	schema := []string{
+		fmt.Sprintf("CREATE TABLE IF NOT EXISTS %s (id VARCHAR(64) PRIMARY KEY NOT NULL DEFAULT '', data BLOB NOT NULL, last_active BIGINT NOT NULL DEFAULT 0, expiration BIGINT NOT NULL DEFAULT 0)", table),
+		fmt.Sprintf("CREATE INDEX IF NOT EXISTS %s_last_active ON %s (last_active)", table, table),
+		fmt.Sprintf("CREATE INDEX IF NOT EXISTS %s_expiration ON %s (expiration)", table, table),
+	}
+
+	for _, stmt := range schema {
+		if _, err = db.Exec(stmt); err != nil {
+			return nil, err
+		}
+	}
+
+	if err = db.Ping(); err != nil {
+		return nil, err
+	}
+
+	return provider, nil
+}
+
+// Get returns the stored session payload, or empty bytes when not found.
+func (p *Provider) Get(id []byte) ([]byte, error) {
+	var data []byte
+
+	switch err := p.db.QueryRow(p.sqlGet, string(id)).Scan(&data); err {
+	case nil:
+		return data, nil
+	case sql.ErrNoRows:
+		return []byte(""), nil
+	default:
+		return nil, err
+	}
+}
+
+// Save upserts the session payload.
+func (p *Provider) Save(id, data []byte, expiration time.Duration) error {
+	now := time.Now().UnixNano()
+
+	res, err := p.db.Exec(p.sqlSave, data, now, expiration.Nanoseconds(), string(id))
+	if err != nil {
+		return err
+	}
+
+	if n, _ := res.RowsAffected(); n == 0 {
+		_, err = p.db.Exec(p.sqlInsert, string(id), data, now, expiration.Nanoseconds())
+	}
+
+	return err
+}
+
+// Destroy removes a session.
+func (p *Provider) Destroy(id []byte) error {
+	_, err := p.db.Exec(p.sqlDestroy, string(id))
+
+	return err
+}
+
+// Regenerate changes a session id, preserving its data.
+func (p *Provider) Regenerate(id, newID []byte, expiration time.Duration) error {
+	now := time.Now().UnixNano()
+
+	res, err := p.db.Exec(p.sqlRegenerate, string(newID), now, expiration.Nanoseconds(), string(id))
+	if err != nil {
+		return err
+	}
+
+	if n, _ := res.RowsAffected(); n == 0 {
+		_, err = p.db.Exec(p.sqlInsert, string(newID), []byte(""), now, expiration.Nanoseconds())
+	}
+
+	return err
+}
+
+// Count returns the number of stored sessions.
+func (p *Provider) Count() int {
+	var n int
+
+	_ = p.db.QueryRow(p.sqlCount).Scan(&n)
+
+	return n
+}
+
+// NeedGC reports that this provider requires periodic garbage collection.
+func (p *Provider) NeedGC() bool { return true }
+
+// GC deletes expired sessions.
+func (p *Provider) GC() error {
+	_, err := p.db.Exec(p.sqlGC, time.Now().UnixNano())
+
+	return err
+}
